---
import "../styles/global.css";
import { getLang, localizedHref, STRINGS } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const lang = getLang(Astro.url);
const s = STRINGS[lang];
const altLang = lang === "zh" ? "en" : "zh";

const {
  title,
  description = s.site_description,
  ogImage = "/og.png",
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalUrl = new URL(localizedHref(pathname, lang), Astro.site).href;
const absoluteOgImage = new URL(ogImage, Astro.site).href;
const altHref = localizedHref(pathname, altLang);
const zhHref = new URL(localizedHref(pathname, "zh"), Astro.site).href;
const enHref = new URL(localizedHref(pathname, "en"), Astro.site).href;
const isActive = (path: string) =>
  path === "/" ? pathname === "/" : pathname.startsWith(path);

// Lang-aware internal hrefs for nav + footer index.
const homeHref = localizedHref("/", lang);
const statsHref = localizedHref("/stats", lang);
const mentorsHref = localizedHref("/mentors", lang);
const aboutHref = localizedHref("/about", lang);
---

<!doctype html>
<html lang={s.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Spectral:ital,wght@0,400;0,500;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f3ea" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh-CN" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <script is:inline>
      // Persist explicit ?lang choice; otherwise honor previously-stored preference.
      (function () {
        try {
          var url = new URL(window.location.href);
          var urlLang = url.searchParams.get("lang");
          if (urlLang === "en" || urlLang === "zh") {
            localStorage.setItem("preferredLang", urlLang);
            return;
          }
          var stored = localStorage.getItem("preferredLang");
          if (stored === "en") {
            url.searchParams.set("lang", "en");
            window.location.replace(url.toString());
          }
        } catch (e) {
          /* ignore — localStorage may be unavailable in some embeds */
        }
      })();
    </script>
  </head>
  <body class="bg-paper text-ink min-h-screen flex flex-col overflow-x-hidden">
    <header class="border-b border-rule">
      <div
        class="max-w-6xl mx-auto px-5 sm:px-10 py-5 sm:py-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between sm:gap-8"
      >
        <a href={homeHref} class="block group">
          <p
            class="font-mono text-[9px] sm:text-[10px] uppercase tracking-[0.25em] text-ink-soft mb-1"
          >
            {s.masthead_volume}
          </p>
          <h1
            class="font-display font-semibold text-2xl sm:text-4xl tracking-tight text-ink leading-none group-hover:text-seal transition-colors duration-200"
          >
            100 Apps Journey
          </h1>
        </a>
        <nav
          class="flex items-baseline gap-4 sm:gap-7 font-mono text-[10px] sm:text-xs uppercase tracking-[0.12em] sm:tracking-[0.15em] flex-wrap"
        >
          <a
            href={homeHref}
            class={`hover:text-seal transition-colors duration-200 ${isActive("/") ? "text-ink" : "text-ink-soft"}`}
          >
            {s.nav_pipeline}
          </a>
          <a
            href={statsHref}
            class={`hover:text-seal transition-colors duration-200 ${isActive("/stats") ? "text-ink" : "text-ink-soft"}`}
          >
            {s.nav_standings}
          </a>
          <a
            href={mentorsHref}
            class={`hover:text-seal transition-colors duration-200 ${isActive("/mentors") ? "text-ink" : "text-ink-soft"}`}
          >
            {s.nav_bench}
          </a>
          <a
            href={aboutHref}
            class={`hover:text-seal transition-colors duration-200 ${isActive("/about") ? "text-ink" : "text-ink-soft"}`}
          >
            {s.nav_method}
          </a>
          <a
            href={altHref}
            aria-label={`Switch language to ${altLang === "zh" ? "中文" : "English"}`}
            class="hover:text-seal transition-colors duration-200 text-ink-soft border border-rule rounded-sm px-1.5 py-0.5"
          >
            {s.lang_toggle_to}
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-rule mt-20">
      <div
        class="max-w-6xl mx-auto px-6 sm:px-10 py-10 grid sm:grid-cols-3 gap-8"
      >
        <div>
          <p class="font-display font-medium text-ink mb-1 text-lg">
            100 Apps Journey
          </p>
          <p class="font-body text-sm text-ink-soft leading-snug">
            {s.site_description}
          </p>
        </div>
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3"
          >
            {s.footer_section_index}
          </p>
          <ul class="font-body text-sm space-y-1.5">
            <li>
              <a href={homeHref} class="hover:text-seal transition-colors">{s.nav_pipeline}</a>
            </li>
            <li>
              <a href={statsHref} class="hover:text-seal transition-colors">{s.nav_standings}</a>
            </li>
            <li>
              <a href={mentorsHref} class="hover:text-seal transition-colors">{s.nav_bench}</a>
            </li>
            <li>
              <a href={aboutHref} class="hover:text-seal transition-colors">{s.nav_method}</a>
            </li>
          </ul>
        </div>
        <div class="sm:text-right">
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3"
          >
            {s.footer_section_about_panel}
          </p>
          <p
            class="font-body text-xs text-ink-soft leading-relaxed max-w-sm sm:ml-auto"
          >
            {s.footer_disclaimer}
          </p>
        </div>
      </div>
      <div class="border-t border-rule">
        <div
          class="max-w-6xl mx-auto px-6 sm:px-10 py-4 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft"
        >
          <span>№ 100 / Day {`<= 100`}</span>
          <span>{s.footer_typography_label}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
