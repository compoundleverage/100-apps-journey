---
import { getLang, STRINGS } from "../lib/i18n";

type Status = "idea" | "building" | "shipped" | "killed";

interface Props {
  status: Status;
  size?: "sm" | "md";
}

const { status, size = "sm" } = Astro.props;
const s = STRINGS[getLang(Astro.url)];

const labels: Record<Status, string> = {
  idea: s.status_idea,
  building: s.status_building,
  shipped: s.status_shipped,
  killed: s.status_killed,
};

const config: Record<Status, { mark: string; color: string }> = {
  idea: { mark: "◌", color: "var(--color-idea)" },
  building: { mark: "◐", color: "var(--color-building)" },
  shipped: { mark: "●", color: "var(--color-shipped)" },
  killed: { mark: "✕", color: "var(--color-killed)" },
};

const label = labels[status];
const { mark, color } = config[status];
const padX = size === "sm" ? "px-1.5" : "px-2";
const padY = size === "sm" ? "py-[2px]" : "py-1";
const text = size === "sm" ? "text-[9px]" : "text-[10px]";
---

<span
  class={`inline-flex items-center gap-1 font-mono ${text} ${padX} ${padY} uppercase tracking-[0.18em] border border-current`}
  style={`color: ${color}`}
>
  <span aria-hidden="true" class="leading-none">{mark}</span>
  <span class="leading-none">{label}</span>
</span>
