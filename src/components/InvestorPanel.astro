---
import { getCollection } from "astro:content";
import { getLang, localizedHref, STRINGS } from "../lib/i18n";
import { MAX_SEATS } from "../lib/seated";

interface Evaluation {
  persona: string;
  score: number;
  reasoning: string;
  mentor_version?: "v1-bootstrap" | "v2-distilled";
}

interface Props {
  evaluations: Evaluation[];
  /** Idea slug — required to wire "Talk to" / "Open panel" chat triggers. */
  ideaId?: string;
}

const { evaluations, ideaId } = Astro.props;
const lang = getLang(Astro.url);
const s = STRINGS[lang];

const mentorEntries = await getCollection("mentors");
const mentors = mentorEntries
  .map((m) => ({ slug: m.id, ...m.data }))
  .sort((a, b) => a.sort_order - b.sort_order);

// One card per mentor in sort_order; pair with evaluation if present.
const ordered = mentors.map((mentor) => {
  const evaluation = evaluations.find((e) => e.persona === mentor.slug);
  const isStale =
    evaluation?.mentor_version &&
    evaluation.mentor_version !== mentor.version;
  return { mentor, evaluation, isStale };
});

const versionGlyph = (v: string) => (v === "v2-distilled" ? "●" : "◌");

// Grid is fixed at up to MAX_SEATS columns (4). All catalog cards render
// server-side; client script filters to the visitor's seated set and toggles
// MAX_SEATS placeholder cards to fill the row.
const placeholders = Array.from({ length: MAX_SEATS });
---

<section class="space-y-6" data-investor-panel>
  <header class="border-b border-rule pb-3">
    <p
      class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-soft mb-1"
      data-panel-count
    >
      {s.panel_header_count(mentors.length)}
    </p>
    <h2
      class="font-display text-2xl sm:text-3xl font-medium tracking-tight text-ink"
    >
      {s.panel_header_subtitle}
    </h2>
  </header>

  <div
    class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-rule lg:grid-cols-4"
    data-panel-grid
  >
    {
      ordered.map(({ mentor, evaluation, isStale }) => (
        <article
          class="relative bg-paper px-5 pt-7 pb-6 flex flex-col group/card"
          data-mentor-card
          data-mentor-slug={mentor.slug}
          data-mentor-name={mentor.name}
        >
          <div
            class="absolute top-0 left-0 right-0 h-[3px]"
            style={`background: ${mentor.accent}`}
          />

          <button
            type="button"
            data-panel-unseat
            data-mentor-slug={mentor.slug}
            class="absolute top-1.5 right-1.5 w-6 h-6 flex items-center justify-center rounded-full text-[13px] leading-none font-mono text-ink-soft border border-rule bg-paper hover:bg-rule hover:text-ink transition-colors z-10"
            aria-label={`Unseat ${mentor.name}`}
            title={s.panel_unseat_title(mentor.name)}
          >
            ✕
          </button>

          <div class="flex items-start gap-3 mb-3">
            <span
              class="flex items-center justify-center w-9 h-9 rounded-full font-mono text-[11px] font-medium shrink-0 mt-0.5"
              style={`background-color: color-mix(in oklch, ${mentor.accent} 12%, transparent); color: ${mentor.accent};`}
            >
              {mentor.avatar_initials}
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline gap-2">
                <a
                  href={localizedHref(`/mentors/${mentor.slug}`, lang)}
                  class="font-display font-semibold text-ink leading-tight hover:text-seal transition-colors"
                >
                  {mentor.name}
                </a>
                <span
                  class="text-[11px] leading-none"
                  style={`color: ${mentor.accent}`}
                  title={mentor.version === "v2-distilled" ? s.panel_distilled : s.panel_bootstrap}
                >
                  {versionGlyph(mentor.version)}
                </span>
              </div>
              <p class="font-body italic text-[12.5px] text-ink-soft leading-snug mt-0.5">
                {mentor.short_bio}
              </p>
            </div>
          </div>

          {evaluation ? (
            <>
              <div class="flex items-baseline gap-1.5 mt-2 mb-3">
                <span
                  class="font-display font-medium text-[64px] leading-[0.85] tabular-nums"
                  style={`color: ${mentor.accent}`}
                >
                  {evaluation.score}
                </span>
                <span class="font-mono text-[11px] uppercase tracking-wider text-ink-soft">
                  / 10
                </span>
                {isStale && (
                  <span
                    class="ml-auto font-mono text-[9px] uppercase tracking-[0.15em] text-ink-soft italic"
                    title={s.panel_stale_title(evaluation.mentor_version!, mentor.version)}
                  >
                    {s.panel_stale}
                  </span>
                )}
              </div>
              <p class="font-body text-[13.5px] leading-[1.7] text-ink relative pl-3 border-l border-rule">
                {evaluation.reasoning}
              </p>
              {ideaId && (
                <div class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em]">
                  <button
                    type="button"
                    data-chat-trigger
                    data-chat-mode="1on1"
                    data-chat-idea={ideaId}
                    data-chat-mentor={mentor.slug}
                    data-chat-mentor-name={mentor.name}
                    data-chat-mentor-initials={mentor.avatar_initials}
                    data-chat-mentor-accent={mentor.accent}
                    class="hover:text-seal transition-colors"
                    style={`color: ${mentor.accent}`}
                  >
                    {s.chat_open_with(mentor.name)}
                  </button>
                </div>
              )}
            </>
          ) : (
            <div class="mt-2 mb-3">
              <span class="font-display font-medium text-[40px] leading-none text-ink-soft tabular-nums opacity-30">
                —
              </span>
              <p class="font-body italic text-[13px] text-ink-soft mt-3">
                {s.panel_pending}
              </p>
            </div>
          )}
        </article>
      ))
    }
    {
      placeholders.map(() => (
        <article
          class="relative bg-paper px-5 pt-6 pb-6 flex flex-col"
          data-mentor-placeholder
          hidden
        >
          <div
            class="absolute top-0 left-0 right-0 h-[3px] opacity-20"
            style="background: var(--color-rule)"
          />
          <details class="group/picker" data-seat-picker>
            <summary
              class="list-none cursor-pointer flex items-start gap-3 mb-3 mt-1 hover:opacity-100 opacity-60 transition-opacity"
            >
              <span
                class="flex items-center justify-center w-9 h-9 rounded-full border border-dashed border-rule shrink-0 mt-0.5 text-ink-soft font-mono text-[14px] group-open/picker:rotate-45 transition-transform"
              >
                +
              </span>
              <div class="min-w-0">
                <p class="font-display font-light text-ink leading-tight">
                  {s.panel_pick_mentor_label}
                </p>
                <p class="font-body text-[12.5px] text-ink-soft leading-snug mt-0.5">
                  {s.panel_seat_open_subtitle}
                </p>
              </div>
            </summary>
            <div
              class="mt-2 flex flex-col gap-1 max-h-48 overflow-y-auto pr-1"
              data-pick-list
            >
              <p class="font-body italic text-[12.5px] text-ink-soft" data-pick-empty hidden>
                {s.panel_pick_mentor_empty}
              </p>
            </div>
          </details>
          <p class="font-body text-[12px] text-ink-soft relative pl-3 border-l border-rule opacity-70 mt-auto">
            {s.panel_invite_prefix}{" "}
            <a
              href={localizedHref("/mentors", lang)}
              class="font-mono text-[11px] text-seal hover:text-ink transition-colors"
            >
              /mentors
            </a>
            {lang === "zh" ? "。" : "."}
          </p>
        </article>
      ))
    }
  </div>

  <p
    class="font-body text-xs text-ink-soft max-w-3xl pt-2 leading-relaxed"
  >
    {s.panel_disclaimer_p1} {s.panel_disclaimer_p2}
  </p>
</section>

<script>
  import { getSeatedSlugs, toggleSeat, MAX_SEATS } from "../lib/seated";
  import { getLang, STRINGS } from "../lib/i18n";

  interface Catalogged {
    slug: string;
    name: string;
  }

  function applySeated() {
    const seated = getSeatedSlugs();
    const seatedSet = new Set(seated);
    const panels = document.querySelectorAll<HTMLElement>("[data-investor-panel]");
    if (panels.length === 0) return;

    const lang = getLang(new URL(window.location.href));
    const s = STRINGS[lang];

    for (const panel of panels) {
      const grid = panel.querySelector<HTMLElement>("[data-panel-grid]");
      if (!grid) continue;

      const cards = grid.querySelectorAll<HTMLElement>("[data-mentor-card]");

      // Build catalog of every mentor card (slug + name) for picker rendering.
      const catalog: Catalogged[] = [];
      for (const card of cards) {
        const slug = card.dataset.mentorSlug ?? "";
        if (!slug) continue;
        catalog.push({ slug, name: card.dataset.mentorName ?? slug });
      }

      const seatedCardsBySlug = new Map<string, HTMLElement>();
      let seatedVisible = 0;
      for (const card of cards) {
        const slug = card.dataset.mentorSlug ?? "";
        if (seatedSet.has(slug)) {
          card.hidden = false;
          seatedCardsBySlug.set(slug, card);
          seatedVisible++;
        } else {
          card.hidden = true;
        }
      }

      // Reorder seated cards to match the seated array order.
      for (const slug of seated) {
        const card = seatedCardsBySlug.get(slug);
        if (card) grid.appendChild(card);
      }

      const placeholders = grid.querySelectorAll<HTMLElement>("[data-mentor-placeholder]");
      const emptyCount = Math.max(0, MAX_SEATS - seatedVisible);
      const unseated = catalog.filter((m) => !seatedSet.has(m.slug));

      placeholders.forEach((el, i) => {
        el.hidden = i >= emptyCount;
        if (!el.hidden) {
          grid.appendChild(el);
          populatePicker(el, unseated);
        }
      });

      const count = panel.querySelector<HTMLElement>("[data-panel-count]");
      if (count) count.textContent = s.panel_header_count(seatedVisible);
    }
  }

  function populatePicker(placeholder: HTMLElement, unseated: Catalogged[]) {
    const list = placeholder.querySelector<HTMLElement>("[data-pick-list]");
    const empty = placeholder.querySelector<HTMLElement>("[data-pick-empty]");
    if (!list) return;

    // Wipe previous picker buttons (but keep the empty-state <p>)
    list.querySelectorAll("button[data-pick-slug]").forEach((b) => b.remove());

    if (unseated.length === 0) {
      if (empty) empty.hidden = false;
      return;
    }
    if (empty) empty.hidden = true;

    for (const m of unseated) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.dataset.pickSlug = m.slug;
      btn.className =
        "text-left font-body text-[13px] text-ink hover:text-seal hover:bg-paper-soft px-2 py-1.5 transition-colors";
      btn.textContent = `+ ${m.name}`;
      list.appendChild(btn);
    }
  }

  function bindClicks() {
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      // Unseat click on a seated card
      const unseatBtn = target.closest<HTMLButtonElement>("[data-panel-unseat]");
      if (unseatBtn) {
        e.preventDefault();
        const slug = unseatBtn.dataset.mentorSlug;
        if (slug) toggleSeat(slug);
        return;
      }
      // Seat click from picker
      const pickBtn = target.closest<HTMLButtonElement>("[data-pick-slug]");
      if (pickBtn) {
        e.preventDefault();
        const slug = pickBtn.dataset.pickSlug;
        if (slug) {
          toggleSeat(slug);
          // Collapse the parent <details> so the picker closes after pick
          const det = pickBtn.closest<HTMLDetailsElement>("details[data-seat-picker]");
          if (det) det.open = false;
        }
      }
    });
  }

  function init() {
    bindClicks();
    applySeated();
    window.addEventListener("seated:changed", applySeated);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
