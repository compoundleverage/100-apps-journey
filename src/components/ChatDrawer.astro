---
import { getLang, localizedHref, STRINGS } from "../lib/i18n";

const lang = getLang(Astro.url);
const s = STRINGS[lang];
const settingsHref = localizedHref("/settings", lang);
---

<!-- Drawer + ApiKeyModal: rendered once per layout, controlled by drawer.ts -->

<aside
  id="chat-drawer"
  aria-hidden="true"
  aria-label="Mentor chat"
  class="fixed top-0 right-0 z-40 w-full sm:w-[440px] h-screen bg-paper border-l border-rule shadow-2xl translate-x-full transition-transform duration-300 ease-out flex flex-col"
>
  <!-- accent bar -->
  <div id="chat-accent-bar" class="h-1 w-full bg-seal shrink-0"></div>

  <!-- header -->
  <header class="border-b border-rule px-5 py-3 flex items-center justify-between gap-3 shrink-0">
    <div class="min-w-0 flex-1">
      <p class="font-mono text-[9px] uppercase tracking-[0.22em] text-ink-soft">
        100 Apps Journey
      </p>
      <p
        id="chat-drawer-subtitle"
        class="font-display text-base font-semibold text-ink truncate"
      ></p>
    </div>
    <button
      id="chat-close"
      type="button"
      aria-label={s.chat_close}
      class="font-mono text-xs uppercase tracking-[0.18em] text-ink-soft hover:text-seal transition-colors px-2 py-1"
    >
      ✕
    </button>
  </header>

  <!-- mentor rail (group mode only) -->
  <div
    id="chat-mentor-rail"
    class="hidden flex flex-wrap gap-1.5 px-5 py-2 border-b border-rule shrink-0"
  ></div>

  <!-- thread -->
  <div id="chat-thread" class="flex-1 overflow-y-auto"></div>

  <!-- composer -->
  <footer class="border-t border-rule px-4 py-3 shrink-0">
    <div class="flex items-end gap-2">
      <textarea
        id="chat-composer"
        rows="2"
        placeholder={s.chat_composer_placeholder}
        class="flex-1 bg-transparent border border-rule focus:border-seal outline-none font-body text-[14px] px-3 py-2 resize-none transition-colors"
      ></textarea>
      <button
        id="chat-send"
        type="button"
        class="font-mono text-[10px] uppercase tracking-[0.18em] border border-seal text-seal px-3 py-2 hover:bg-seal hover:text-paper transition-colors disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
      >
        {s.chat_send}
      </button>
    </div>
    <!-- Rescore + clear row. Rescore is disabled until there's been at least one mentor turn (1on1 only — group makes less sense). -->
    <div
      id="chat-rescore-row"
      class="hidden flex items-center justify-between mt-2 gap-3"
    >
      <button
        id="chat-rescore"
        type="button"
        title={s.rescore_btn_disabled_hint}
        class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft border border-rule px-3 py-1.5 hover:text-seal hover:border-seal transition-colors disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:text-ink-soft disabled:hover:border-rule"
        disabled
      >
        {s.rescore_btn}
      </button>
      <p
        id="chat-rescore-status"
        class="font-mono text-[9px] uppercase tracking-[0.16em] text-ink-soft truncate text-right"
      ></p>
    </div>
    <div class="flex justify-between items-center mt-2 font-mono text-[9px] text-ink-soft uppercase tracking-[0.16em]">
      <span>{s.chat_cost_hint}</span>
      <button
        id="chat-clear"
        type="button"
        class="hover:text-seal transition-colors"
      >
        {s.chat_clear_history}
      </button>
    </div>
  </footer>
</aside>

<!-- API Key gate modal -->
<div
  id="api-key-modal"
  class="hidden fixed inset-0 z-50 bg-ink/40 flex items-center justify-center p-5"
>
  <div class="bg-paper border border-rule max-w-md w-full p-6 shadow-2xl">
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-seal mb-3">
      {s.keymodal_title}
    </p>
    <p class="font-body text-[15px] text-ink mb-3 leading-relaxed">
      {s.keymodal_p1}
    </p>
    <p class="font-body italic text-sm text-ink-soft leading-relaxed">
      {s.keymodal_p2}
    </p>
    <div class="flex items-center gap-3 mt-6">
      <a
        href={settingsHref}
        class="font-mono text-xs uppercase tracking-[0.18em] border border-seal text-seal px-4 py-2 hover:bg-seal hover:text-paper transition-colors"
      >
        {s.keymodal_open_settings}
      </a>
      <button
        id="api-key-modal-dismiss"
        type="button"
        class="font-mono text-xs uppercase tracking-[0.18em] text-ink-soft hover:text-ink transition-colors ml-auto"
      >
        {s.keymodal_dismiss}
      </button>
    </div>
  </div>
</div>

<script>
  import { ensureChatDrawer } from "../lib/chat/drawer";
  import { hydrateRefinedCards } from "../lib/chat/clarify";
  // Initialize on DOMContentLoaded — also handles bfcache restores.
  function init() {
    ensureChatDrawer();
    hydrateRefinedCards();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
