---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { averageScore } from "../lib/scoring";
import { effectiveDisclosure, showPanel } from "../lib/disclosure";

const ideas = await getCollection("ideas");

// Only count ideas where the panel is publicly disclosed.
const visibleIdeas = ideas.filter((i) => showPanel(effectiveDisclosure(i.data)));
const allEvals = visibleIdeas.flatMap((i) => i.data.investor_evaluations);

const mentorEntries = await getCollection("mentors");
const PANEL = mentorEntries
  .map((m) => ({
    id: m.id,
    name: m.data.name,
    avatar_initials: m.data.avatar_initials,
    accent: m.data.accent,
    sort_order: m.data.sort_order,
  }))
  .sort((a, b) => a.sort_order - b.sort_order);

// Per-mentor averages
const personaStats = PANEL.map((persona) => {
  const evals = allEvals.filter((e) => e.persona === persona.id);
  const sum = evals.reduce((s, e) => s + e.score, 0);
  const avg = evals.length > 0 ? sum / evals.length : null;
  return { persona, count: evals.length, avg };
});

// Pipeline composition
const total = ideas.length;
const byStatus = {
  idea: ideas.filter((i) => i.data.status === "idea").length,
  building: ideas.filter((i) => i.data.status === "building").length,
  shipped: ideas.filter((i) => i.data.status === "shipped").length,
  killed: ideas.filter((i) => i.data.status === "killed").length,
};

// Most loved (highest avg)
const ranked = ideas
  .map((i) => ({
    idea: i,
    avg: averageScore(i.data.investor_evaluations),
  }))
  .filter((r): r is { idea: typeof ideas[0]; avg: number } => r.avg !== null)
  .sort((a, b) => b.avg - a.avg);

// Most disagreed (max - min)
const disagreed = ideas
  .map((i) => {
    const evals = i.data.investor_evaluations;
    if (evals.length < 2) return null;
    const scores = evals.map((e) => e.score);
    const span = Math.max(...scores) - Math.min(...scores);
    return { idea: i, span, evals };
  })
  .filter((r): r is NonNullable<typeof r> => r !== null)
  .sort((a, b) => b.span - a.span);

// Score distribution (counts per score 1-10)
const scoreDistribution = Array.from({ length: 10 }, (_, i) => {
  const score = i + 1;
  return {
    score,
    count: allEvals.filter((e) => e.score === score).length,
  };
});
const maxBucket = Math.max(...scoreDistribution.map((d) => d.count), 1);

// Per-persona max for bar normalization
const maxPersonaAvg = 10;
---

<Layout title="The Standings · 100 Apps Journey">
  <article>
    <header class="border-b border-rule">
      <div
        class="max-w-6xl mx-auto px-6 sm:px-10 pt-12 sm:pt-20 pb-10 sm:pb-12"
      >
        <div class="flex items-center gap-3 mb-5 entry-rise">
          <span class="block w-6 h-px bg-seal"></span>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal"
          >
            The Standings
          </p>
        </div>
        <h1
          class="font-display text-[2.25rem] sm:text-[3.5rem] font-medium tracking-[-0.02em] leading-[0.95] max-w-3xl entry-rise"
          style="animation-delay: 0.05s"
        >
          What the panel<br />
          <span class="italic font-light text-ink-soft">tends to think.</span>
        </h1>
      </div>
    </header>

    {
      total === 0 ? (
        <section class="max-w-3xl mx-auto px-6 sm:px-10 py-24 text-center">
          <p class="font-display text-2xl text-ink mb-3">
            Nothing logged yet.
          </p>
          <p class="font-body italic text-ink-soft">
            The standings come into focus once entries accumulate.
          </p>
        </section>
      ) : (
        <>
          {/* Pipeline composition */}
          <section class="border-b border-rule">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-10 sm:py-12">
              <div class="grid sm:grid-cols-[auto_1fr] gap-x-10 gap-y-4 mb-8">
                <h2 class="font-display text-xl sm:text-2xl font-medium tracking-tight">
                  Pipeline composition
                </h2>
                <p class="font-body italic text-ink-soft text-sm sm:text-base max-w-xl">
                  Where the {total} logged ideas currently stand. The shape
                  of the curve tells you whether the pipeline is healthy —
                  too many <em>ideas</em> is paralysis; too few <em>killed</em> is
                  attachment.
                </p>
              </div>

              <div class="grid grid-cols-2 sm:grid-cols-4 gap-y-6 gap-x-4">
                {(["idea", "building", "shipped", "killed"] as const).map(
                  (key) => {
                    const value = byStatus[key];
                    const pct = total > 0 ? (value / total) * 100 : 0;
                    const color =
                      key === "idea"
                        ? "var(--color-idea)"
                        : key === "building"
                          ? "var(--color-building)"
                          : key === "shipped"
                            ? "var(--color-shipped)"
                            : "var(--color-killed)";
                    return (
                      <div>
                        <p class="font-mono text-[9px] uppercase tracking-[0.2em] text-ink-soft mb-1">
                          {key}
                        </p>
                        <p
                          class="font-display text-3xl sm:text-4xl font-medium tabular-nums leading-none"
                          style={`color: ${color}`}
                        >
                          {value}
                        </p>
                        <p class="font-mono text-[10px] tabular-nums text-ink-soft mt-1.5">
                          {pct.toFixed(0)}%
                        </p>
                      </div>
                    );
                  }
                )}
              </div>
            </div>
          </section>

          {/* Per-persona averages */}
          <section class="border-b border-rule">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-10 sm:py-12">
              <div class="grid sm:grid-cols-[auto_1fr] gap-x-10 gap-y-4 mb-8">
                <h2 class="font-display text-xl sm:text-2xl font-medium tracking-tight">
                  Panel averages
                </h2>
                <p class="font-body italic text-ink-soft text-sm sm:text-base max-w-xl">
                  Each panelist's mean score across all logged ideas. Outliers
                  matter more than the absolute number — who is consistently
                  harder, who is the cheerleader, where do they diverge.
                </p>
              </div>

              <ul class="space-y-4 max-w-3xl">
                {personaStats.map(({ persona, count, avg }) => {
                  const pct =
                    avg !== null ? (avg / maxPersonaAvg) * 100 : 0;
                  return (
                    <li class="grid grid-cols-[auto_1fr_auto] gap-4 items-center">
                      <span
                        class="flex items-center justify-center w-9 h-9 rounded-full font-mono text-[11px] font-medium shrink-0"
                        style={`background-color: color-mix(in oklch, ${persona.accent} 12%, transparent); color: ${persona.accent};`}
                      >
                        {persona.avatar_initials}
                      </span>
                      <div class="min-w-0">
                        <p class="font-display font-semibold text-ink leading-tight truncate">
                          {persona.name}
                        </p>
                        <div class="mt-2 h-[3px] bg-rule relative">
                          <span
                            class="block h-full transition-[width] duration-700"
                            style={`width: ${pct}%; background: ${persona.accent}`}
                          ></span>
                        </div>
                      </div>
                      <div class="text-right tabular-nums shrink-0">
                        <p
                          class="font-display text-2xl sm:text-3xl font-medium leading-none"
                          style={
                            avg !== null
                              ? `color: ${persona.accent}`
                              : "color: var(--color-ink-soft)"
                          }
                        >
                          {avg !== null ? avg.toFixed(1) : "—"}
                        </p>
                        <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-ink-soft mt-1">
                          {count} eval{count === 1 ? "" : "s"}
                        </p>
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </section>

          {/* Score distribution */}
          <section class="border-b border-rule">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-10 sm:py-12">
              <div class="grid sm:grid-cols-[auto_1fr] gap-x-10 gap-y-4 mb-8">
                <h2 class="font-display text-xl sm:text-2xl font-medium tracking-tight">
                  Score distribution
                </h2>
                <p class="font-body italic text-ink-soft text-sm sm:text-base max-w-xl">
                  How the {allEvals.length} individual evaluations cluster.
                  A bimodal shape suggests strong opinions; a tight middle
                  suggests the panel is being polite.
                </p>
              </div>

              <div class="flex items-end gap-1 sm:gap-2 max-w-3xl h-32 sm:h-40 border-b border-rule">
                {scoreDistribution.map(({ score, count }) => {
                  const h = (count / maxBucket) * 100;
                  return (
                    <div class="flex-1 flex flex-col justify-end items-center group">
                      <span class="font-mono text-[10px] tabular-nums text-ink-soft mb-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        {count}
                      </span>
                      <div
                        class="w-full bg-seal/20"
                        style={`height: ${h}%; min-height: ${count > 0 ? "2px" : "0"}`}
                      ></div>
                    </div>
                  );
                })}
              </div>
              <div class="flex gap-1 sm:gap-2 max-w-3xl mt-2">
                {scoreDistribution.map(({ score }) => (
                  <span class="flex-1 text-center font-mono text-[10px] tabular-nums text-ink-soft">
                    {score}
                  </span>
                ))}
              </div>
            </div>
          </section>

          {/* Top + Disagreed */}
          <section>
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-10 sm:py-14 grid lg:grid-cols-2 gap-10 lg:gap-16">
              <div>
                <h2 class="font-display text-xl sm:text-2xl font-medium tracking-tight mb-2">
                  Top of the deck
                </h2>
                <p class="font-body italic text-ink-soft text-sm mb-6">
                  Highest panel averages.
                </p>
                {ranked.length === 0 ? (
                  <p class="font-body italic text-ink-soft text-sm">
                    No scored entries yet.
                  </p>
                ) : (
                  <ol class="space-y-4">
                    {ranked.slice(0, 5).map(({ idea, avg }, i) => (
                      <li class="grid grid-cols-[auto_1fr_auto] gap-4 items-baseline border-b border-rule pb-3">
                        <span class="font-mono text-xs text-ink-soft tabular-nums">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        <a
                          href={`/ideas/${idea.id}`}
                          class="font-display font-medium text-ink hover:text-seal transition-colors leading-tight"
                        >
                          {idea.data.title}
                        </a>
                        <span class="font-display text-2xl font-medium text-seal tabular-nums leading-none">
                          {avg.toFixed(1)}
                        </span>
                      </li>
                    ))}
                  </ol>
                )}
              </div>

              <div>
                <h2 class="font-display text-xl sm:text-2xl font-medium tracking-tight mb-2">
                  Most divisive
                </h2>
                <p class="font-body italic text-ink-soft text-sm mb-6">
                  Largest spread between best and worst score.
                </p>
                {disagreed.length === 0 ? (
                  <p class="font-body italic text-ink-soft text-sm">
                    Need at least two evaluations to spot disagreement.
                  </p>
                ) : (
                  <ol class="space-y-4">
                    {disagreed.slice(0, 5).map(({ idea, span }, i) => (
                      <li class="grid grid-cols-[auto_1fr_auto] gap-4 items-baseline border-b border-rule pb-3">
                        <span class="font-mono text-xs text-ink-soft tabular-nums">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        <a
                          href={`/ideas/${idea.id}`}
                          class="font-display font-medium text-ink hover:text-seal transition-colors leading-tight"
                        >
                          {idea.data.title}
                        </a>
                        <span class="font-display text-2xl font-medium text-ink tabular-nums leading-none">
                          ±{span}
                        </span>
                      </li>
                    ))}
                  </ol>
                )}
              </div>
            </div>
          </section>
        </>
      )
    }
  </article>
</Layout>
