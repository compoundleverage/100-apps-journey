---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const mentorEntries = await getCollection("mentors");
const mentors = mentorEntries
  .map((m) => ({ slug: m.id, ...m.data }))
  .sort((a, b) => a.sort_order - b.sort_order);

const versionGlyph = (v: string) => (v === "v2-distilled" ? "●" : "◌");

const total = mentors.length;
const distilled = mentors.filter((m) => m.version === "v2-distilled").length;
const bootstraps = total - distilled;
---

<Layout title="The Panel · 100 Apps Journey">
  <article>
    <header class="border-b border-rule">
      <div
        class="max-w-6xl mx-auto px-6 sm:px-10 pt-12 sm:pt-20 pb-10 sm:pb-12"
      >
        <div class="flex items-center gap-3 mb-5 entry-rise">
          <span class="block w-6 h-px bg-seal"></span>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal"
          >
            The Bench
          </p>
        </div>
        <h1
          class="font-display text-[2.5rem] sm:text-[3.5rem] font-medium tracking-[-0.02em] leading-[0.95] max-w-3xl entry-rise"
          style="animation-delay: 0.05s"
        >
          The voices on the panel.
        </h1>
        <p
          class="font-body italic text-base sm:text-lg text-ink-soft max-w-2xl leading-snug mt-6 entry-rise"
          style="animation-delay: 0.1s"
        >
          Each idea is evaluated by AI simulations of these real builders.
          They reason in their own voice, draw on their own mental models, and
          disagree productively.
        </p>
      </div>
    </header>

    {
      total === 0 ? (
        <section class="max-w-3xl mx-auto px-6 sm:px-10 py-24 text-center">
          <p class="font-display text-3xl text-ink-soft italic mb-6">
            The bench is empty.
          </p>
          <p class="font-body italic text-sm text-ink-soft">
            Forge the first mentor below.
          </p>
        </section>
      ) : (
        <>
          <section class="border-b border-rule">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-6">
              <div class="flex flex-wrap items-baseline gap-x-8 gap-y-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft">
                <span>
                  <span class="text-ink tabular-nums">{total}</span> on the bench
                </span>
                <span class="opacity-50">·</span>
                <span>
                  <span class="text-ink tabular-nums">{distilled}</span> ● fully forged
                </span>
                <span class="opacity-50">·</span>
                <span>
                  <span class="text-ink tabular-nums">{bootstraps}</span> ◌ in sketch
                </span>
              </div>
            </div>
          </section>

          <section>
            {mentors.map((mentor) => (
              <a href={`/mentors/${mentor.slug}`} class="block group">
                <article class="border-b border-rule grid grid-cols-[auto_auto_1fr_auto] gap-4 sm:gap-8 items-baseline px-6 sm:px-10 py-6 sm:py-7 transition-colors duration-200 group-hover:bg-paper-soft">
                  <span
                    class="flex items-center justify-center w-9 h-9 rounded-full font-mono text-[11px] font-medium shrink-0 self-center"
                    style={`background-color: color-mix(in oklch, ${mentor.accent} 12%, transparent); color: ${mentor.accent};`}
                  >
                    {mentor.avatar_initials}
                  </span>

                  <span
                    class="font-display text-[26px] leading-none shrink-0 self-center"
                    style={`color: ${mentor.accent}`}
                    title={mentor.version}
                  >
                    {versionGlyph(mentor.version)}
                  </span>

                  <div class="min-w-0">
                    <h3 class="font-display text-lg sm:text-2xl font-medium tracking-tight leading-[1.15] text-ink group-hover:text-seal transition-colors duration-200">
                      {mentor.name}
                    </h3>
                    <p class="font-body italic text-sm sm:text-base text-ink-soft leading-snug mt-1 max-w-3xl">
                      {mentor.short_bio}
                    </p>
                    <div class="flex items-center gap-3 sm:gap-4 mt-3 font-mono text-[10px] uppercase tracking-[0.15em] text-ink-soft flex-wrap">
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.mental_models.length}
                        </span>{" "}
                        mental models
                      </span>
                      <span class="opacity-50">·</span>
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.decision_heuristics.length}
                        </span>{" "}
                        heuristics
                      </span>
                      <span class="opacity-50">·</span>
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.primary_sources.length}
                        </span>{" "}
                        primary sources
                      </span>
                    </div>
                  </div>

                  <div class="hidden sm:flex flex-col items-end gap-1 shrink-0 self-center text-right">
                    <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-ink-soft">
                      {mentor.version === "v2-distilled" ? "Forged" : "Sketch"}
                    </span>
                    <span class="font-mono text-[10px] tabular-nums text-ink-soft">
                      {mentor.research_date.toISOString().slice(0, 10)}
                    </span>
                  </div>
                </article>
              </a>
            ))}
          </section>
        </>
      )
    }

    <!-- Forge a new mentor — visible regardless of bench state -->
    <section class="border-t border-rule" style="background: var(--color-paper-soft)">
      <div class="max-w-3xl mx-auto px-6 sm:px-10 py-12 sm:py-16">
        <div class="flex items-center gap-3 mb-5">
          <span class="block w-6 h-px bg-seal"></span>
          <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal">
            Forge a new mentor
          </p>
        </div>
        <h2 class="font-display text-2xl sm:text-3xl font-medium tracking-tight mb-4 leading-[1.15]">
          The bench is closed by design.
        </h2>
        <p class="font-body italic text-sm sm:text-base text-ink-soft max-w-2xl leading-snug mb-10">
          There is no "Add" button. Each mentor is distilled in Claude Code
          through a six-agent research pipeline. Type a name and we'll give
          you the exact command to paste — the pipeline does the rest.
        </p>

        <!-- Form -->
        <div class="space-y-6 max-w-2xl">
          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2 block">
              Name
            </span>
            <input
              id="mentor-name"
              type="text"
              placeholder="Steve Jobs"
              autocomplete="off"
              class="w-full bg-transparent border-b border-ink/30 focus:border-seal outline-none font-display text-2xl sm:text-3xl py-2 px-0 transition-colors text-ink"
            />
          </label>

          <div>
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2 block">
              Paste in Claude Code
            </span>
            <div class="flex items-stretch gap-px bg-rule border border-rule">
              <code
                id="forge-command"
                class="flex-1 bg-paper px-4 py-3 font-mono text-sm text-ink overflow-x-auto whitespace-nowrap"
              >/persona-forge "Steve Jobs"</code>
              <button
                id="copy-btn"
                type="button"
                class="bg-paper px-4 py-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft hover:text-seal transition-colors shrink-0"
              >
                Copy
              </button>
            </div>
            <p
              id="copy-feedback"
              class="font-mono text-[10px] uppercase tracking-[0.2em] text-seal mt-2 h-3 opacity-0 transition-opacity"
            >
              Copied to clipboard
            </p>
          </div>
        </div>

        <!-- Prerequisites & cost -->
        <div class="mt-12 pt-6 border-t border-rule grid sm:grid-cols-2 gap-x-10 gap-y-6 max-w-3xl">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3">
              Prerequisites
            </p>
            <ul class="font-body text-sm text-ink space-y-1.5">
              <li><span class="text-ink-soft mr-1">—</span>Node 22+ with Bun ≥ 1.1</li>
              <li><span class="text-ink-soft mr-1">—</span>Claude Code installed and this project open</li>
              <li>
                <span class="text-ink-soft mr-1">—</span>
                <code class="font-mono text-xs">.env</code> with{" "}
                <code class="font-mono text-xs">ANTHROPIC_API_KEY</code>
              </li>
            </ul>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3">
              Cost &amp; time
            </p>
            <ul class="font-body text-sm text-ink space-y-1.5">
              <li><span class="text-ink-soft mr-1">—</span>≈ $1–2 per forge in API charges</li>
              <li><span class="text-ink-soft mr-1">—</span>5–15 min execution</li>
              <li>
                <span class="text-ink-soft mr-1">—</span>plus 30 min of attention if you review checkpoints honestly
              </li>
            </ul>
          </div>
        </div>

        <p class="font-body italic text-xs text-ink-soft mt-10 leading-relaxed">
          The pipeline distills mental models, decision heuristics, and
          expression DNA from public sources — books, talks, interviews,
          microblogs — scoring each on a four-dimension reliability rubric.
          Output lands in{" "}
          <code class="font-mono text-xs not-italic">
            src/content/mentors/&lt;slug&gt;/
          </code>{" "}
          and the new mentor immediately joins the panel. To resume an
          interrupted run:{" "}
          <code class="font-mono text-xs not-italic text-seal">
            /persona-forge --resume &lt;slug&gt;
          </code>
          .
        </p>
      </div>
    </section>
  </article>

  <script is:inline>
    (function () {
      const input = document.getElementById("mentor-name");
      const cmd = document.getElementById("forge-command");
      const btn = document.getElementById("copy-btn");
      const feedback = document.getElementById("copy-feedback");
      if (!input || !cmd || !btn || !feedback) return;

      function escapeName(name) {
        return name.replace(/"/g, '\\"');
      }

      function updateCommand() {
        const name = input.value.trim() || "Steve Jobs";
        cmd.textContent = `/persona-forge "${escapeName(name)}"`;
      }

      input.addEventListener("input", updateCommand);

      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(cmd.textContent);
          feedback.style.opacity = "1";
          setTimeout(() => {
            feedback.style.opacity = "0";
          }, 1500);
        } catch (e) {
          const range = document.createRange();
          range.selectNode(cmd);
          const sel = window.getSelection();
          if (sel) {
            sel.removeAllRanges();
            sel.addRange(range);
          }
        }
      });
    })();
  </script>
</Layout>
