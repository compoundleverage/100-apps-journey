---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getLang, localizedHref, STRINGS } from "../../lib/i18n";
import { MAX_SEATS } from "../../lib/seated";

const mentorEntries = await getCollection("mentors");
const mentors = mentorEntries
  .map((m) => ({ slug: m.id, ...m.data }))
  .sort((a, b) => a.sort_order - b.sort_order);

const versionGlyph = (v: string) => (v === "v2-distilled" ? "●" : "◌");

const total = mentors.length;
const distilled = mentors.filter((m) => m.version === "v2-distilled").length;
const bootstraps = total - distilled;

const lang = getLang(Astro.url);
const s = STRINGS[lang];
---

<Layout title={s.bench_page_title}>
  <article>
    <header class="border-b border-rule">
      <div
        class="max-w-6xl mx-auto px-6 sm:px-10 pt-12 sm:pt-20 pb-10 sm:pb-12"
      >
        <div class="flex items-center gap-3 mb-5 entry-rise">
          <span class="block w-6 h-px bg-seal"></span>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal"
          >
            {s.bench_section_label}
          </p>
        </div>
        <h1
          class="font-display text-[2.5rem] sm:text-[3.5rem] font-medium tracking-[-0.02em] leading-[0.95] max-w-3xl entry-rise"
          style="animation-delay: 0.05s"
        >
          {s.bench_headline_l2}
        </h1>
        <p
          class="font-body text-base sm:text-lg text-ink-soft max-w-2xl leading-snug mt-6 entry-rise"
          style="animation-delay: 0.1s"
        >
          {s.bench_intro}
        </p>
      </div>
    </header>

    {
      total === 0 ? (
        <section class="max-w-3xl mx-auto px-6 sm:px-10 py-24 text-center">
          <p class="font-display text-3xl text-ink-soft italic mb-6">
            {s.bench_empty_title}
          </p>
          <p class="font-body italic text-sm text-ink-soft">
            {s.bench_empty_subtitle}
          </p>
        </section>
      ) : (
        <>
          <section class="border-b border-rule">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 py-6">
              <div class="flex flex-wrap items-baseline gap-x-8 gap-y-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft">
                <span>{s.bench_count_seated(total)}</span>
                <span class="opacity-50">·</span>
                <span>{s.bench_count_distilled(distilled)}</span>
                <span class="opacity-50">·</span>
                <span>{s.bench_count_bootstrap(bootstraps)}</span>
              </div>
            </div>
          </section>

          <!-- "Your bench" — populated client-side from localStorage; server renders empty -->
          <section class="border-b border-rule" data-bench-section="seated">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 pt-10 pb-2 flex items-baseline justify-between gap-4 flex-wrap">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal mb-2">
                  {s.bench_your_section}
                </p>
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-soft" data-bench-seated-header>
                  {s.bench_seated_header(0, MAX_SEATS)}
                </p>
              </div>
              <button
                type="button"
                data-bench-reset
                class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft hover:text-seal transition-colors underline-offset-4 hover:underline"
              >
                {s.bench_seat_reset}
              </button>
            </div>
            <div data-bench-seated-list>
              <!-- script moves seated mentor cards here -->
            </div>
            <p
              class="max-w-6xl mx-auto px-6 sm:px-10 pb-6 font-body italic text-sm text-ink-soft"
              data-bench-seated-empty
              hidden
            >
              {s.bench_seated_empty}
            </p>
            <p class="max-w-6xl mx-auto px-6 sm:px-10 pb-6 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft opacity-70">
              {s.bench_seat_persisted_hint}
            </p>
          </section>

          <!-- "Available mentors" — server renders all mentor cards here; script
               moves seated ones up to "Your bench" on hydrate. -->
          <section data-bench-section="available">
            <div class="max-w-6xl mx-auto px-6 sm:px-10 pt-10 pb-3">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal mb-2">
                {s.bench_available_section}
              </p>
              <p class="font-body text-sm text-ink-soft">
                {s.bench_available_subtitle}
              </p>
            </div>
            <div data-bench-available-list>
              {mentors.map((mentor) => (
                <div
                  class="border-b border-rule grid grid-cols-[auto_auto_1fr_auto] gap-4 sm:gap-8 items-baseline px-6 sm:px-10 py-6 sm:py-7 transition-colors hover:bg-paper-soft"
                  data-mentor-card
                  data-mentor-slug={mentor.slug}
                  data-mentor-name={mentor.name}
                  data-mentor-accent={mentor.accent}
                  data-mentor-initials={mentor.avatar_initials}
                  data-mentor-short-bio={mentor.short_bio}
                >
                  <span
                    class="flex items-center justify-center w-9 h-9 rounded-full font-mono text-[11px] font-medium shrink-0 self-center"
                    style={`background-color: color-mix(in oklch, ${mentor.accent} 12%, transparent); color: ${mentor.accent};`}
                  >
                    {mentor.avatar_initials}
                  </span>

                  <span
                    class="font-display text-[26px] leading-none shrink-0 self-center"
                    style={`color: ${mentor.accent}`}
                    title={mentor.version}
                  >
                    {versionGlyph(mentor.version)}
                  </span>

                  <div class="min-w-0">
                    <a
                      href={localizedHref(`/mentors/${mentor.slug}`, lang)}
                      class="inline-block group/name"
                    >
                      <h3 class="font-display text-lg sm:text-2xl font-medium tracking-tight leading-[1.15] text-ink group-hover/name:text-seal transition-colors duration-200">
                        {mentor.name}
                      </h3>
                    </a>
                    <p class="font-body italic text-sm sm:text-base text-ink-soft leading-snug mt-1 max-w-3xl">
                      {mentor.short_bio}
                    </p>
                    <div class="flex items-center gap-3 sm:gap-4 mt-3 font-mono text-[10px] uppercase tracking-[0.15em] text-ink-soft flex-wrap">
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.mental_models.length}
                        </span>{" "}
                        {s.bench_card_models}
                      </span>
                      <span class="opacity-50">·</span>
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.decision_heuristics.length}
                        </span>{" "}
                        {s.bench_card_heuristics}
                      </span>
                      <span class="opacity-50">·</span>
                      <span>
                        <span class="text-ink tabular-nums">
                          {mentor.primary_sources.length}
                        </span>{" "}
                        {s.bench_card_sources}
                      </span>
                    </div>
                  </div>

                  <div class="flex flex-col items-end gap-2 shrink-0 self-center text-right">
                    <span class="hidden sm:inline-block font-mono text-[9px] uppercase tracking-[0.2em] text-ink-soft">
                      {mentor.version === "v2-distilled" ? s.bench_card_distilled : s.bench_card_bootstrap}
                    </span>
                    <span class="hidden sm:inline-block font-mono text-[10px] tabular-nums text-ink-soft">
                      {mentor.research_date.toISOString().slice(0, 10)}
                    </span>
                    <button
                      type="button"
                      data-seat-toggle
                      class="font-mono text-[10px] uppercase tracking-[0.18em] py-1.5 px-3 border border-rule transition-colors hover:bg-seal/10 hover:text-seal disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:bg-transparent disabled:hover:text-ink-soft"
                      style={`color: ${mentor.accent}; border-color: color-mix(in oklch, ${mentor.accent} 30%, var(--color-rule));`}
                    >
                      {s.bench_seat_action}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </>
      )
    }

    <!-- Forge a new mentor — visible regardless of bench state -->
    <section class="border-t border-rule" style="background: var(--color-paper-soft)">
      <div class="max-w-3xl mx-auto px-6 sm:px-10 py-12 sm:py-16">
        <div class="flex items-center gap-3 mb-5">
          <span class="block w-6 h-px bg-seal"></span>
          <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal">
            {s.bench_distill_section}
          </p>
        </div>
        <h2 class="font-display text-2xl sm:text-3xl font-medium tracking-tight mb-4 leading-[1.15]">
          {s.bench_distill_intro}
        </h2>
        <p class="font-body text-sm sm:text-base text-ink-soft max-w-2xl leading-snug mb-10">
          {s.bench_distill_explainer}
        </p>

        <!-- Form -->
        <div class="space-y-6 max-w-2xl">
          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2 block">
              {s.bench_distill_name_label}
            </span>
            <input
              id="mentor-name"
              type="text"
              placeholder="Steve Jobs"
              autocomplete="off"
              class="w-full bg-transparent border-b border-ink/30 focus:border-seal outline-none font-display text-2xl sm:text-3xl py-2 px-0 transition-colors text-ink"
            />
          </label>

          <div>
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2 block">
              {s.bench_distill_paste_label}
            </span>
            <div class="flex items-stretch gap-px bg-rule border border-rule">
              <code
                id="forge-command"
                class="flex-1 bg-paper px-4 py-3 font-mono text-sm text-ink overflow-x-auto whitespace-nowrap"
              >/persona-forge "Steve Jobs"</code>
              <button
                id="copy-btn"
                type="button"
                class="bg-paper px-4 py-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft hover:text-seal transition-colors shrink-0"
              >
                {s.bench_distill_copy}
              </button>
            </div>
            <p
              id="copy-feedback"
              class="font-mono text-[10px] uppercase tracking-[0.2em] text-seal mt-2 h-3 opacity-0 transition-opacity"
            >
              {s.bench_distill_copied}
            </p>
          </div>
        </div>

        <!-- Prerequisites & cost -->
        <div class="mt-12 pt-6 border-t border-rule grid sm:grid-cols-2 gap-x-10 gap-y-6 max-w-3xl">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3">
              {s.bench_distill_prereq_title}
            </p>
            <ul class="font-body text-sm text-ink space-y-1.5">
              <li><span class="text-ink-soft mr-1">—</span>{s.bench_distill_prereq_node}</li>
              <li><span class="text-ink-soft mr-1">—</span>{s.bench_distill_prereq_cc}</li>
              <li>
                <span class="text-ink-soft mr-1">—</span>
                <code class="font-mono text-xs">ANTHROPIC_API_KEY</code> {s.bench_distill_prereq_env}{" "}
                <code class="font-mono text-xs">.env</code>
              </li>
            </ul>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-3">
              {s.bench_distill_cost_title}
            </p>
            <ul class="font-body text-sm text-ink space-y-1.5">
              <li><span class="text-ink-soft mr-1">—</span>{s.bench_distill_cost_api}</li>
              <li><span class="text-ink-soft mr-1">—</span>{s.bench_distill_cost_time}</li>
              <li>
                <span class="text-ink-soft mr-1">—</span>{s.bench_distill_cost_review}
              </li>
            </ul>
          </div>
        </div>

        <p class="font-body text-xs text-ink-soft mt-10 leading-relaxed">
          {s.bench_distill_pipeline_p1}{" "}
          <code class="font-mono text-xs">
            src/content/mentors/&lt;slug&gt;/
          </code>
          {lang === "zh" ? "，" : ", "}{s.bench_distill_pipeline_p2}{" "}
          <code class="font-mono text-xs text-seal">
            /persona-forge --resume &lt;slug&gt;
          </code>
          {lang === "zh" ? "。" : "."}
        </p>
      </div>
    </section>
  </article>

  <script is:inline>
    (function () {
      const input = document.getElementById("mentor-name");
      const cmd = document.getElementById("forge-command");
      const btn = document.getElementById("copy-btn");
      const feedback = document.getElementById("copy-feedback");
      if (!input || !cmd || !btn || !feedback) return;

      function escapeName(name) {
        return name.replace(/"/g, '\\"');
      }

      function updateCommand() {
        const name = input.value.trim() || "Steve Jobs";
        cmd.textContent = `/persona-forge "${escapeName(name)}"`;
      }

      input.addEventListener("input", updateCommand);

      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(cmd.textContent);
          feedback.style.opacity = "1";
          setTimeout(() => {
            feedback.style.opacity = "0";
          }, 1500);
        } catch (e) {
          const range = document.createRange();
          range.selectNode(cmd);
          const sel = window.getSelection();
          if (sel) {
            sel.removeAllRanges();
            sel.addRange(range);
          }
        }
      });
    })();
  </script>

  <script>
    import {
      getSeatedSlugs,
      toggleSeat,
      resetSeats,
      MAX_SEATS,
    } from "../../lib/seated";
    import { getLang, STRINGS } from "../../lib/i18n";

    function render() {
      const seated = getSeatedSlugs();
      const seatedSet = new Set(seated);
      const lang = getLang(new URL(window.location.href));
      const s = STRINGS[lang];

      const seatedList = document.querySelector<HTMLElement>("[data-bench-seated-list]");
      const availableList = document.querySelector<HTMLElement>("[data-bench-available-list]");
      const seatedHeader = document.querySelector<HTMLElement>("[data-bench-seated-header]");
      const seatedEmpty = document.querySelector<HTMLElement>("[data-bench-seated-empty]");
      if (!seatedList || !availableList) return;

      // Gather all cards from both lists (cards may live in either after toggles)
      const allCards = document.querySelectorAll<HTMLElement>("[data-mentor-card]");
      const cardBySlug = new Map<string, HTMLElement>();
      for (const card of allCards) {
        const slug = card.dataset.mentorSlug ?? "";
        if (slug) cardBySlug.set(slug, card);
      }

      // Move seated cards in order to seatedList; rest stay in availableList
      // (any seated card currently in available gets moved up; vice versa).
      for (const slug of seated) {
        const card = cardBySlug.get(slug);
        if (card) seatedList.appendChild(card);
      }
      // Any remaining cards (not in seated) belong in available
      for (const [slug, card] of cardBySlug) {
        if (!seatedSet.has(slug) && card.parentElement !== availableList) {
          availableList.appendChild(card);
        }
      }

      // Update header count
      if (seatedHeader) {
        seatedHeader.textContent = s.bench_seated_header(seated.length, MAX_SEATS);
      }
      if (seatedEmpty) {
        seatedEmpty.hidden = seated.length > 0;
      }

      // Update each toggle button (label, disabled state)
      const isFull = seated.length >= MAX_SEATS;
      for (const [slug, card] of cardBySlug) {
        const btn = card.querySelector<HTMLButtonElement>("[data-seat-toggle]");
        if (!btn) continue;
        const inSeated = seatedSet.has(slug);
        btn.textContent = inSeated ? s.bench_unseat_action : s.bench_seat_action;
        btn.disabled = !inSeated && isFull;
        btn.title = btn.disabled ? s.bench_seat_full_hint(MAX_SEATS) : "";
      }
    }

    function bindClicks() {
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement | null;
        if (!target) return;
        const toggleBtn = target.closest<HTMLButtonElement>("[data-seat-toggle]");
        if (toggleBtn && !toggleBtn.disabled) {
          const card = toggleBtn.closest<HTMLElement>("[data-mentor-card]");
          const slug = card?.dataset.mentorSlug;
          if (slug) {
            toggleSeat(slug);
            render();
          }
          return;
        }
        const resetBtn = target.closest<HTMLElement>("[data-bench-reset]");
        if (resetBtn) {
          resetSeats();
          render();
        }
      });
    }

    function init() {
      bindClicks();
      render();
      window.addEventListener("seated:changed", render);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  </script>
</Layout>
