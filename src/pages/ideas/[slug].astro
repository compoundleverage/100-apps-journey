---
import Layout from "../../layouts/Layout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import InvestorPanel from "../../components/InvestorPanel.astro";
import GroupChatTrigger from "../../components/GroupChatTrigger.astro";
import LiveStateNote from "../../components/LiveStateNote.astro";
import { averageScore } from "../../lib/scoring";
import {
  effectiveDisclosure,
  showThesis,
  showBody,
  showPanel,
} from "../../lib/disclosure";
import { getCollection, render } from "astro:content";
import { getLang, localizedHref, STRINGS } from "../../lib/i18n";

// SSR mode: fetch the idea by slug at request time.
// Returns 404 if no match — keeps behavior consistent with previous static build.
const { slug } = Astro.params;
const ideas = await getCollection("ideas");
const idea = ideas.find((i) => i.id === slug);
if (!idea) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
const data = idea.data;
const disclosure = effectiveDisclosure(data);
const showsThesis = showThesis(disclosure);
const showsBody = showBody(disclosure);
const showsPanel = showPanel(disclosure);

const lang = getLang(Astro.url);
const s = STRINGS[lang];

const { Content } = await render(idea);
const avg = averageScore(data.investor_evaluations);
const idStr = String(data.id).padStart(3, "0");
const dateAdded = data.date_added.toISOString().slice(0, 10);
const dateShipped = data.date_shipped?.toISOString().slice(0, 10);
const dateKilled = data.date_killed?.toISOString().slice(0, 10);

const description = showsThesis ? data.thesis : s.idea_stealth_description(idStr);

// Per-idea OG only when the thesis is disclosed; otherwise fall back to site default
// so we don't leak gated content via the social card.
const ogImage = showsThesis ? `/og/ideas/${idea.id}.png` : "/og.png";
---

<Layout
  title={`${data.title} · 100 Apps Journey`}
  description={description}
  ogImage={ogImage}
>
  <article>
    <header class="border-b border-rule">
      <div
        class="max-w-4xl mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-10 sm:pb-12"
      >
        <div class="flex items-center gap-3 mb-5 entry-rise">
          <span class="block w-6 h-px bg-seal"></span>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-seal"
          >
            {s.idea_entry_label(idStr)}
          </p>
        </div>

        <h1
          class="font-display text-[2.25rem] sm:text-5xl lg:text-[3.5rem] font-medium tracking-[-0.018em] leading-[0.98] text-ink max-w-3xl mb-6 entry-rise"
          style="animation-delay: 0.05s"
        >
          {data.title}
        </h1>

        <div
          class="flex items-center gap-x-3 gap-y-2 flex-wrap font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft entry-rise"
          style="animation-delay: 0.1s"
        >
          <StatusBadge status={data.status} />
          <span class="opacity-50">·</span>
          <span>{s.idea_recorded} {dateAdded}</span>
          {
            showsThesis && (
              <>
                <span class="opacity-50">·</span>
                <span>{s.idea_budget} {data.time_budget}</span>
              </>
            )
          }
          {
            dateShipped && (
              <>
                <span class="opacity-50">·</span>
                <span>{s.idea_shipped_at} {dateShipped}</span>
              </>
            )
          }
          {
            dateKilled && (
              <>
                <span class="opacity-50">·</span>
                <span>{s.idea_killed_at} {dateKilled}</span>
              </>
            )
          }
          {
            showsThesis && data.tags.length > 0 && (
              <>
                <span class="opacity-50">·</span>
                <span>{data.tags.join(" / ")}</span>
              </>
            )
          }
          {
            !showsThesis && (
              <>
                <span class="opacity-50">·</span>
                <span class="italic">{s.idea_stealth_inline}</span>
              </>
            )
          }
        </div>
      </div>
    </header>

    {
      showsThesis ? (
        <section class="border-b border-rule">
          <div class="max-w-4xl mx-auto px-6 sm:px-10 py-10 sm:py-12 grid sm:grid-cols-[1fr_auto] gap-y-8 gap-x-10 items-start">
            <div class="space-y-8">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-soft mb-3">
                  Thesis
                </p>
                <p class="font-display text-[1.35rem] sm:text-[1.65rem] font-light leading-[1.55] text-ink max-w-2xl">
                  {data.thesis}
                </p>
              </div>
              <div class="pl-5 border-l-2 border-seal max-w-2xl">
                <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-soft mb-2">
                  Kill Criteria
                </p>
                <p class="font-body text-[15px] text-ink-soft leading-relaxed">
                  {data.kill_criteria}
                </p>
              </div>
            </div>
            {showsPanel && avg !== null ? (
              <aside class="sm:text-right shrink-0 sm:min-w-[140px] sm:border-l border-rule sm:pl-8 sm:py-2">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2">
                  {s.idea_panel_avg}
                </p>
                <p class="font-display text-[5rem] sm:text-[6rem] font-medium leading-[0.85] text-seal tabular-nums">
                  {avg}
                </p>
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mt-2">
                  {s.idea_panel_avg_count(data.investor_evaluations.length)}
                </p>
              </aside>
            ) : showsPanel ? (
              <aside class="sm:text-right shrink-0 sm:min-w-[140px] sm:border-l border-rule sm:pl-8 sm:py-2">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft mb-2">
                  {s.idea_panel_section}
                </p>
                <p class="font-body italic text-sm text-ink-soft">
                  {s.idea_panel_pending}
                </p>
              </aside>
            ) : null}
          </div>
        </section>
      ) : (
        <section class="border-b border-rule">
          <div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 text-center">
            <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-soft mb-4">
              {s.idea_sealed_title}
            </p>
            <p class="font-display text-2xl sm:text-3xl font-light text-ink-soft leading-snug max-w-xl mx-auto">
              {s.idea_sealed_p1}
            </p>
            <p class="font-body italic text-sm text-ink-soft mt-6 max-w-md mx-auto">
              {s.idea_sealed_p2}
            </p>
          </div>
        </section>
      )
    }

    {
      showsPanel && (
        <section class="border-b border-rule">
          <div class="max-w-6xl mx-auto px-6 sm:px-10 py-12 sm:py-16">
            <InvestorPanel evaluations={data.investor_evaluations} ideaId={idea.id} />
            <div class="mt-8 flex justify-center">
              <GroupChatTrigger ideaId={idea.id} />
            </div>
          </div>
        </section>
      )
    }

    {
      showsBody && (
        <section>
          <div class="max-w-3xl mx-auto px-6 sm:px-10 py-12 sm:py-16">
            <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-soft mb-6">
              {s.idea_body_section}
            </p>
            {data.id === 1 && <LiveStateNote />}
            <div class="prose-journal">
              <Content />
            </div>

            {(data.url || data.repo) && (
              <div class="mt-12 pt-6 border-t border-rule flex gap-6 font-mono text-xs uppercase tracking-[0.15em]">
                {data.url && (
                  <a
                    href={data.url}
                    class="text-seal hover:text-ink transition-colors"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {s.idea_link_url}
                  </a>
                )}
                {data.repo && (
                  <a
                    href={data.repo}
                    class="text-seal hover:text-ink transition-colors"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {s.idea_link_repo}
                  </a>
                )}
              </div>
            )}
          </div>
        </section>
      )
    }

    <nav class="border-t border-rule">
      <div
        class="max-w-3xl mx-auto px-6 sm:px-10 py-6 flex items-center justify-between"
      >
        <a
          href={localizedHref("/", lang)}
          class="font-mono text-xs uppercase tracking-[0.2em] text-ink-soft hover:text-seal transition-colors"
        >
          {s.idea_back_to_pipeline}
        </a>
        <span
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-soft hidden sm:inline"
        >
          {s.idea_footer(idStr)}
        </span>
      </div>
    </nav>
  </article>
</Layout>
